  "keyFeatures": [
    "Driver standings tracking with points calculation",
    "Constructor championship standings",
    "Race schedule and results management",
    "User authentication and registration",
    "CRUD operations for drivers, teams, and races",
    "Database-driven architecture with Prisma ORM",
    "Vue.js reactive frontend interface",
    "RESTful API with Nitro.js backend"
  ],
  "publicApiSurface": [
    "GET /api/drivers - List all drivers with standings",
    "POST /api/drivers/create - Create new driver",
    "PUT /api/drivers/update - Update driver information",
    "DELETE /api/drivers/delete - Delete driver",
    "GET /api/teams - List all teams with points",
    "POST /api/teams/create - Create new team",
    "PUT /api/teams/update - Update team information",
    "DELETE /api/teams/delete - Delete team",
    "GET /api/races - List all races",
    "POST /api/races/create - Create new race",
    "PUT /api/races/update - Update race information",
    "DELETE /api/races/delete - Delete race",
    "GET /api/results - Get race results",
    "POST /api/user/register - Register new user",
    "POST /api/user/login - User login"
  ]
